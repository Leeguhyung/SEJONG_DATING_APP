{
  "expo": {
    "name": "세종설렘",
    "slug": "sejong-dating",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/center_logo.svg",
    "scheme": "sejongdating",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sejong.dating"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#D29793",
        "foregroundImage": "./assets/images/center_logo.svg"
      },
      "package": "com.sejong.dating",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/center_logo.svg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/center_logo.svg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#D29793"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
